generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoPessoa {
  MORADOR
  FUNCIONARIO
  TERCEIRO
  PRESTADOR
  VISITANTE
  SINDICO
  ADMINISTRADOR
}

enum TipoEmpresa {
  TERCEIRIZADA
  PRESTADORA
  FORNECEDOR
}

enum PerfilUsuario {
  SUPER_ADMIN
  ADMIN_CONDOMINIO
  PORTARIA
  TECNICO
  MORADOR
}

enum TipoCredencial {
  FACIAL
  TAG
  SENHA
}

enum TipoAcesso {
  FACIAL
  TAG
  SENHA
  VISITANTE_IA
  VISITANTE_MANUAL
}

enum StatusAcesso {
  AUTORIZADO
  NEGADO
  PENDENTE
}
enum StatusVisita {
  PENDENTE
  AUTORIZADO
  NEGADO
  EM_ANDAMENTO
  FINALIZADO
  CANCELADO
}

enum TipoVisita {
  AVULSA
  AGENDADA
  PRESTADOR
  ENTREGA
}
enum TipoAcionamentoPortao {
  SIMULADO
  HTTP
  RELE
  API
}
enum TemaUsuario {
  ESCURO
  CLARO
}

model Pessoa {
  id             Int        @id @default(autoincrement())
  condominioId   Int
  empresaId      Int?
  nome           String
  documento      String?
  telefone       String?
  email          String?
  tipo           TipoPessoa
  rg             String?
  funcao         String?
  observacao     String?
  validadeInicio DateTime?
  validadeFim    DateTime?
  ativo          Boolean    @default(true)
  criadoEm       DateTime   @default(now())

  condominio Condominio       @relation(fields: [condominioId], references: [id])
  empresa    EmpresaTerceira? @relation(fields: [empresaId], references: [id])

  unidades    PessoaUnidade[]
  credenciais CredencialAcesso[]
  acessos     EventoAcesso[]
  visitasResponsavel Visita[] @relation("PessoaResponsavelVisita")
  visitasAutorizadasComoPessoa Visita[] @relation("PessoaAutorizouVisita")
}

model PessoaUnidade {
  id        Int      @id @default(autoincrement())
  pessoaId  Int
  unidadeId Int
  relacao   String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  pessoa  Pessoa  @relation(fields: [pessoaId], references: [id])
  unidade Unidade @relation(fields: [unidadeId], references: [id])

  @@unique([pessoaId, unidadeId])
}

model EmpresaTerceira {
  id           Int         @id @default(autoincrement())
  condominioId Int
  nome         String
  documento    String?
  telefone     String?
  email        String?
  tipo         TipoEmpresa
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  pessoas    Pessoa[]
}

model Condominio {
  id          Int      @id @default(autoincrement())
  nome        String
  documento   String?
  telefone    String?
  email       String?
  responsavel String?
  cep         String?
  endereco    String?
  numero      String?
  bairro      String?
  cidade      String?
  estado      String?
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())

  usuarios          Usuario[]
  unidades          Unidade[]
  moradores         Morador[]
  dispositivos      Dispositivo[]
  visitantes        Visitante[]
  visitas           Visita[]
  acessos           EventoAcesso[]
  pessoas           Pessoa[]
  empresasTerceiras EmpresaTerceira[]
  configuracao Configuracao?
}

model Usuario {
  id           Int           @id @default(autoincrement())
  condominioId Int?
  nome         String
  email        String        @unique
  senhaHash    String
  perfil       PerfilUsuario
  tema TemaUsuario @default(ESCURO)
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())

  condominio Condominio? @relation(fields: [condominioId], references: [id])
  visitasAutorizadas Visita[]
}

model Unidade {
  id            Int     @id @default(autoincrement())
  condominioId  Int
  identificacao String
  bloco         String?
  ativo         Boolean @default(true)

  condominio Condominio      @relation(fields: [condominioId], references: [id])
  moradores  Morador[]
  pessoas    PessoaUnidade[]
  visitas    Visita[]
}

model Morador {
  id           Int      @id @default(autoincrement())
  condominioId Int
  unidadeId    Int
  nome         String
  telefone     String?
  email        String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  unidade    Unidade    @relation(fields: [unidadeId], references: [id])

  credenciais CredencialAcesso[]
  acessos     EventoAcesso[]
}

model CredencialAcesso {
  id            Int            @id @default(autoincrement())
  condominioId  Int
  moradorId     Int
  pessoaId      Int?
  tipo          TipoCredencial
  identificador String
  ativo         Boolean        @default(true)
  criadoEm      DateTime       @default(now())

  morador Morador @relation(fields: [moradorId], references: [id])
  pessoa  Pessoa? @relation(fields: [pessoaId], references: [id])

  @@unique([condominioId, tipo, identificador])
}

model Dispositivo {
  id           Int       @id @default(autoincrement())
  condominioId Int
  nome         String
  tipo         String
  fabricante   String?
  modelo       String?
  ip           String?
  porta        Int?
  usuario      String?
  senha        String?
  localizacao  String?
  status       String?   @default("DESCONHECIDO")
  ultimoCheck  DateTime?
  config       Json?
  ativo        Boolean   @default(true)

  condominio Condominio     @relation(fields: [condominioId], references: [id])
  acessos    EventoAcesso[]
  visitas    Visita[]
}

model Visitante {
  id           Int      @id @default(autoincrement())
  condominioId Int
  nome         String
  documento    String?
  telefone     String?
  criadoEm     DateTime @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  visitas    Visita[]
}

model Visita {
  id              Int          @id @default(autoincrement())
  condominioId    Int
  visitanteId     Int?
  unidadeId       Int?
  pessoaResponsavelId Int?
  autorizadoPorPessoaId Int?
  dispositivoId   Int?
  autorizadoPorId Int?

  nomeVisitante   String
  documento       String?
  telefone        String?
  motivo          String?
  observacao      String?

  tipo            TipoVisita   @default(AVULSA)
  status          StatusVisita @default(PENDENTE)

  dataPrevista    DateTime?
  entradaEm       DateTime?
  saidaEm         DateTime?
  autorizadoEm    DateTime?
  negadoEm        DateTime?
  canceladoEm     DateTime?

  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt

  condominio      Condominio   @relation(fields: [condominioId], references: [id])
  visitante       Visitante?   @relation(fields: [visitanteId], references: [id])
  unidade         Unidade?     @relation(fields: [unidadeId], references: [id])
  pessoaResponsavel Pessoa? @relation("PessoaResponsavelVisita", fields: [pessoaResponsavelId], references: [id])
  autorizadoPorPessoa Pessoa? @relation("PessoaAutorizouVisita", fields: [autorizadoPorPessoaId], references: [id])
  dispositivo     Dispositivo? @relation(fields: [dispositivoId], references: [id])
  autorizadoPor   Usuario?     @relation(fields: [autorizadoPorId], references: [id])
}
model EventoAcesso {
  id            Int          @id @default(autoincrement())
  condominioId  Int
  moradorId     Int?
  pessoaId      Int?
  dispositivoId Int?
  tipo          TipoAcesso
  origem        String?
  nome          String?
  unidade       String?
  status        StatusAcesso
  criadoEm      DateTime     @default(now())

  condominio  Condominio   @relation(fields: [condominioId], references: [id])
  morador     Morador?     @relation(fields: [moradorId], references: [id])
  pessoa      Pessoa?      @relation(fields: [pessoaId], references: [id])
  dispositivo Dispositivo? @relation(fields: [dispositivoId], references: [id])
}
model Configuracao {
  id           Int      @id @default(autoincrement())
  condominioId Int     @unique

  tempoMaximoPermanenciaHoras Int     @default(12)
  permitirEntradaSemAutorizacao Boolean @default(false)
  exigirUnidade Boolean @default(true)
  exigirMoradorResponsavel Boolean @default(true)

  abrirPortaoAutomaticamente Boolean @default(false)
  registrarEntradaAutomaticamente Boolean @default(true)
  exigirConfirmacaoPorteiro Boolean @default(true)
  permitirEntradaDireta Boolean @default(false)

  tipoAcionamentoPortao TipoAcionamentoPortao @default(SIMULADO)
  ipDispositivoPortao String?
  portaDispositivoPortao Int?
  tempoAberturaSegundos Int @default(2)

  criadoEm DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  condominio Condominio @relation(fields: [condominioId], references: [id])
}
