generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoPessoa {
  MORADOR
  FUNCIONARIO
  TERCEIRO
  PRESTADOR
  VISITANTE
  SINDICO
  ADMINISTRADOR
}

enum TipoEmpresa {
  TERCEIRIZADA
  PRESTADORA
  FORNECEDOR
}

enum PerfilUsuario {
  SUPER_ADMIN
  ADMIN_CONDOMINIO
  PORTARIA
  TECNICO
  MORADOR
}

enum TipoCredencial {
  FACIAL
  TAG
  SENHA
}

enum TipoAcesso {
  FACIAL
  TAG
  SENHA
  VISITANTE_IA
  VISITANTE_MANUAL
}

enum StatusAcesso {
  AUTORIZADO
  NEGADO
  PENDENTE
}

enum StatusVisita {
  PENDENTE
  AUTORIZADO
  NEGADO
  EM_ANDAMENTO
  FINALIZADO
  CANCELADO
}

enum TipoVisita {
  AVULSA
  AGENDADA
  PRESTADOR
  ENTREGA
}

enum TipoAcionamentoPortao {
  SIMULADO
  HTTP
  RELE
  API
}

enum TemaUsuario {
  ESCURO
  CLARO
}

enum StatusEncomenda {
  PENDENTE
  NOTIFICADO
  RETIRADO
  CANCELADO
}

enum ModoEnvioWhatsapp {
  MANUAL
  AUTOMATICO
}

model IntegradorWhatsappConfig {
  id Int @id @default(autoincrement())

  integradorId Int @unique

  modo  ModoEnvioWhatsapp @default(MANUAL)
  ativo Boolean           @default(false)

  phoneNumberId String?
  accessToken   String?

  templateEncomenda String? @default("encomenda_recebida")
  templateIdioma    String? @default("pt_BR")

  fallbackManual Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  integrador Integrador @relation(fields: [integradorId], references: [id])
}

model Encomenda {
  id           Int  @id @default(autoincrement())
  condominioId Int
  unidadeId    Int?
  pessoaId     Int?

  descricao String?
  codigo    String?
  remetente String?

  status StatusEncomenda @default(PENDENTE)

  dataRecebimento DateTime  @default(now())
  notificadoEm    DateTime?
  retiradoEm      DateTime?
  canceladoEm     DateTime?

  recebidoPorId Int?
  retiradoPorId Int?

  observacao     String?
  codigoRetirada String?
  codigoExpiraEm DateTime?

  mensagemWhatsapp String?
  whatsappEnviado  Boolean @default(false)
  whatsappErro     String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  condominio Condominio @relation(fields: [condominioId], references: [id])
  unidade    Unidade?   @relation(fields: [unidadeId], references: [id])
  pessoa     Pessoa?    @relation(fields: [pessoaId], references: [id])
}

model Pessoa {
  id             Int        @id @default(autoincrement())
  condominioId   Int
  empresaId      Int?
  nome           String
  documento      String?
  telefone       String?
  email          String?
  tipo           TipoPessoa
  rg             String?
  funcao         String?
  observacao     String?
  validadeInicio DateTime?
  validadeFim    DateTime?
  ativo          Boolean    @default(true)
  criadoEm       DateTime   @default(now())

  condominio Condominio       @relation(fields: [condominioId], references: [id])
  empresa    EmpresaTerceira? @relation(fields: [empresaId], references: [id])

  unidades                     PessoaUnidade[]
  credenciais                  CredencialAcesso[]
  acessos                      EventoAcesso[]
  visitasResponsavel           Visita[]           @relation("PessoaResponsavelVisita")
  visitasAutorizadasComoPessoa Visita[]           @relation("PessoaAutorizouVisita")
  encomendas                   Encomenda[]
}

model PessoaUnidade {
  id        Int      @id @default(autoincrement())
  pessoaId  Int
  unidadeId Int
  relacao   String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  pessoa  Pessoa  @relation(fields: [pessoaId], references: [id])
  unidade Unidade @relation(fields: [unidadeId], references: [id])

  @@unique([pessoaId, unidadeId])
}

model EmpresaTerceira {
  id           Int         @id @default(autoincrement())
  condominioId Int
  nome         String
  documento    String?
  telefone     String?
  email        String?
  tipo         TipoEmpresa
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  pessoas    Pessoa[]
}

model Condominio {
  id           Int      @id @default(autoincrement())
  integradorId Int?
  nome         String
  documento    String?
  telefone     String?
  email        String?
  responsavel  String?
  cep          String?
  endereco     String?
  numero       String?
  bairro       String?
  cidade       String?
  estado       String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())

  integrador        Integrador?        @relation(fields: [integradorId], references: [id])
  usuarios          Usuario[]
  unidades          Unidade[]
  moradores         Morador[]
  dispositivos      Dispositivo[]
  visitantes        Visitante[]
  visitas           Visita[]
  acessos           EventoAcesso[]
  pessoas           Pessoa[]
  modulos           CondominioModulo[]
  credenciais       CredencialAcesso[]
  empresasTerceiras EmpresaTerceira[]
  configuracao      Configuracao?
  encomendas        Encomenda[]
}

model Usuario {
  id           Int           @id @default(autoincrement())
  condominioId Int?
  nome         String
  email        String        @unique
  senhaHash    String
  perfil       PerfilUsuario
  tema         TemaUsuario   @default(ESCURO)
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())

  condominio         Condominio? @relation(fields: [condominioId], references: [id])
  visitasAutorizadas Visita[]
}

model Unidade {
  id            Int     @id @default(autoincrement())
  condominioId  Int
  identificacao String
  bloco         String?
  ativo         Boolean @default(true)

  condominio Condominio      @relation(fields: [condominioId], references: [id])
  moradores  Morador[]
  pessoas    PessoaUnidade[]
  visitas    Visita[]
  encomendas Encomenda[]
}

model Morador {
  id           Int      @id @default(autoincrement())
  condominioId Int
  unidadeId    Int
  nome         String
  telefone     String?
  email        String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  unidade    Unidade    @relation(fields: [unidadeId], references: [id])

  credenciais CredencialAcesso[]
  acessos     EventoAcesso[]
}

model CredencialAcesso {
  id            Int            @id @default(autoincrement())
  condominioId  Int
  moradorId     Int?
  pessoaId      Int
  tipo          TipoCredencial
  identificador String
  ativo         Boolean        @default(true)
  criadoEm      DateTime       @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  morador    Morador?   @relation(fields: [moradorId], references: [id])
  pessoa     Pessoa     @relation(fields: [pessoaId], references: [id])
}

model Dispositivo {
  id           Int       @id @default(autoincrement())
  condominioId Int
  nome         String
  tipo         String
  fabricante   String?
  modelo       String?
  ip           String?
  porta        Int?
  usuario      String?
  senha        String?
  localizacao  String?
  status       String?   @default("DESCONHECIDO")
  ultimoCheck  DateTime?
  config       Json?
  ativo        Boolean   @default(true)

  condominio Condominio     @relation(fields: [condominioId], references: [id])
  acessos    EventoAcesso[]
  visitas    Visita[]
}

model Visitante {
  id           Int      @id @default(autoincrement())
  condominioId Int
  nome         String
  documento    String?
  telefone     String?
  criadoEm     DateTime @default(now())

  condominio Condominio @relation(fields: [condominioId], references: [id])
  visitas    Visita[]
}

model Visita {
  id                    Int  @id @default(autoincrement())
  condominioId          Int
  visitanteId           Int?
  unidadeId             Int?
  pessoaResponsavelId   Int?
  autorizadoPorPessoaId Int?
  dispositivoId         Int?
  autorizadoPorId       Int?

  nomeVisitante String
  documento     String?
  telefone      String?
  motivo        String?
  observacao    String?

  tipo   TipoVisita   @default(AVULSA)
  status StatusVisita @default(PENDENTE)

  dataPrevista DateTime?
  entradaEm    DateTime?
  saidaEm      DateTime?
  autorizadoEm DateTime?
  negadoEm     DateTime?
  canceladoEm  DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  condominio          Condominio   @relation(fields: [condominioId], references: [id])
  visitante           Visitante?   @relation(fields: [visitanteId], references: [id])
  unidade             Unidade?     @relation(fields: [unidadeId], references: [id])
  pessoaResponsavel   Pessoa?      @relation("PessoaResponsavelVisita", fields: [pessoaResponsavelId], references: [id])
  autorizadoPorPessoa Pessoa?      @relation("PessoaAutorizouVisita", fields: [autorizadoPorPessoaId], references: [id])
  dispositivo         Dispositivo? @relation(fields: [dispositivoId], references: [id])
  autorizadoPor       Usuario?     @relation(fields: [autorizadoPorId], references: [id])
}

model EventoAcesso {
  id            Int          @id @default(autoincrement())
  condominioId  Int
  moradorId     Int?
  pessoaId      Int?
  dispositivoId Int?
  tipo          TipoAcesso
  origem        String?
  nome          String?
  unidade       String?
  status        StatusAcesso
  criadoEm      DateTime     @default(now())

  condominio  Condominio   @relation(fields: [condominioId], references: [id])
  morador     Morador?     @relation(fields: [moradorId], references: [id])
  pessoa      Pessoa?      @relation(fields: [pessoaId], references: [id])
  dispositivo Dispositivo? @relation(fields: [dispositivoId], references: [id])
}

model Configuracao {
  id           Int @id @default(autoincrement())
  condominioId Int @unique

  tempoMaximoPermanenciaHoras   Int     @default(12)
  permitirEntradaSemAutorizacao Boolean @default(false)
  exigirUnidade                 Boolean @default(true)
  exigirMoradorResponsavel      Boolean @default(true)

  abrirPortaoAutomaticamente      Boolean @default(false)
  registrarEntradaAutomaticamente Boolean @default(true)
  exigirConfirmacaoPorteiro       Boolean @default(true)
  permitirEntradaDireta           Boolean @default(false)

  tipoAcionamentoPortao  TipoAcionamentoPortao @default(SIMULADO)
  ipDispositivoPortao    String?
  portaDispositivoPortao Int?
  tempoAberturaSegundos  Int                   @default(2)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  condominio Condominio @relation(fields: [condominioId], references: [id])
}

model Permissao {
  id        Int     @id @default(autoincrement())
  chave     String  @unique
  descricao String?

  perfis PerfilPermissao[]
}

model PerfilPermissao {
  id          Int           @id @default(autoincrement())
  perfil      PerfilUsuario
  permissaoId Int

  permissao Permissao @relation(fields: [permissaoId], references: [id])

  @@unique([perfil, permissaoId])
}

model Modulo {
  id        Int     @id @default(autoincrement())
  chave     String  @unique
  nome      String
  descricao String?
  ativo     Boolean @default(true)
  ordem     Int     @default(0)

  condominios CondominioModulo[]
}

model CondominioModulo {
  id           Int     @id @default(autoincrement())
  condominioId Int
  moduloId     Int
  ativo        Boolean @default(true)

  condominio Condominio @relation(fields: [condominioId], references: [id])
  modulo     Modulo     @relation(fields: [moduloId], references: [id])

  @@unique([condominioId, moduloId])
}

model Integrador {
  id           Int      @id @default(autoincrement())
  nome         String
  slug         String   @unique
  dominio      String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tema           IntegradorTema?
  condominios    Condominio[]
  whatsappConfig IntegradorWhatsappConfig?
}

model IntegradorTema {
  id           Int @id @default(autoincrement())
  integradorId Int @unique

  nomeSistema String?
  logoUrl     String?
  faviconUrl  String?

  primaryColor     String @default("#2563eb")
  primarySoftColor String @default("#eff6ff")
  sidebarColor     String @default("#111827")
  bgColor          String @default("#f5f7fb")
  cardColor        String @default("#ffffff")
  textColor        String @default("#172033")
  mutedColor       String @default("#64748b")
  borderColor      String @default("#e5e7eb")

  integrador Integrador @relation(fields: [integradorId], references: [id])
}
